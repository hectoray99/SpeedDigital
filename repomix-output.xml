                        <button onClick={() => setStep(1)} className="text-slate-400 hover:text-slate-600 text-sm font-bold mb-6 flex items-center gap-1 transition-colors px-3 py-1.5 -ml-3 rounded-lg hover:bg-slate-100">
                            Volver atrás
                        </button>
                        
                        <div className="mb-8">
