import { useEffect, useState, useRef } from 'react';
import { supabase } from '../../../lib/supabase';
import { useAuthStore } from '../../../store/authStore';
import { Loader2, ScanLine, UserCheck, UserMinus } from 'lucide-react';
import { toast } from 'sonner';

export default function Timeclock() {
    const { orgData } = useAuthStore();
    const [currentTime, setCurrentTime] = useState(new Date());
    const [inputValue, setInputValue] = useState('');
    const [isProcessing, setIsProcessing] = useState(false);
    
    const inputRef = useRef<HTMLInputElement>(null);

    useEffect(() => {
        const timer = setInterval(() => setCurrentTime(new Date()), 1000);
        return () => clearInterval(timer);
    }, []);

    useEffect(() => {
        const focusTimer = setInterval(() => {
            if (!isProcessing && inputRef.current && document.activeElement !== inputRef.current) {
                inputRef.current.focus();
            }
        }, 3000);
        return () => clearInterval(focusTimer);
    }, [isProcessing]);

    const handlePunch = async (e: React.FormEvent) => {
        e.preventDefault();
        
        const documentNumber = inputValue.trim();
        if (!documentNumber) return;
        
        setIsProcessing(true);

        try {
            // 1. BUSCAR A LA PERSONA POR IDENTIFIER (DNI)
            // Usamos identifier que es la columna real de tu base de datos
            const { data: person, error: personError } = await supabase
                .from('crm_people')
                .select('id, full_name, type')
                .eq('organization_id', orgData!.id)
                .eq('identifier', documentNumber) // <--- COLUMNA CORRECTA
                .in('type', ['employee', 'staff'])
                .eq('is_active', true)
                .maybeSingle();

            if (personError) {
                console.error("Error de búsqueda:", personError);
                throw new Error("Error técnico al buscar el DNI.");
            }

            if (!person) {
                setInputValue('');
                throw new Error("DNI no reconocido. Verificá que esté cargado en la sección de Personal.");
            }

            // 2. BUSCAR EL ESTADO DE HOY
            const today = new Date().toLocaleDateString('en-CA'); 
            
            const { data: lastRecord, error: searchError } = await supabase
                .from('staff_attendance')
                .select('*')
                .eq('organization_id', orgData!.id)
                .eq('person_id', person.id)
                .eq('work_date', today)
                .order('created_at', { ascending: false })
                .limit(1)
                .maybeSingle();

            if (searchError) throw searchError;

            // 3. REGISTRAR ENTRADA O SALIDA
            if (!lastRecord || lastRecord.check_out) {
                const { error: insertError } = await supabase
                    .from('staff_attendance')
                    .insert([{
                        organization_id: orgData!.id,
                        person_id: person.id,
                        work_date: today,
                        check_in: new Date().toISOString(),
                        status: 'present'
                    }]);

                if (insertError) throw insertError;
                toast.success(
                    <div className="flex flex-col text-left">
                        <span className="font-black text-indigo-900 text-lg">¡Hola, {person.full_name.split(' ')[0]}!</span>
                        <span className="text-sm font-bold text-indigo-600">Entrada: {new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}hs</span>
                    </div>, 
                    { icon: <UserCheck className="w-6 h-6 text-emerald-500" />, duration: 4000 }
                );
            } else {
                const { error: updateError } = await supabase
                    .from('staff_attendance')
                    .update({ check_out: new Date().toISOString() })
                    .eq('id', lastRecord.id);

                if (updateError) throw updateError;
                toast.info(
                    <div className="flex flex-col text-left">
                        <span className="font-black text-slate-900 text-lg">¡Chau, {person.full_name.split(' ')[0]}!</span>
                        <span className="text-sm font-bold text-slate-500">Salida: {new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}hs</span>
                    </div>, 
                    { icon: <UserMinus className="w-6 h-6 text-indigo-500" />, duration: 4000 }
                );
            }

            setInputValue('');

        } catch (error: any) {
            toast.error(error.message || "Error procesando el fichaje.");
            setInputValue('');
        } finally {
            setIsProcessing(false);
            setTimeout(() => inputRef.current?.focus(), 100);
        }
    };

    return (
        <div className="min-h-[85vh] flex flex-col items-center justify-center p-4 animate-in fade-in duration-700">
            
            <div className="text-center mb-10">
                <h1 className="text-7xl md:text-9xl font-black text-slate-900 tracking-tighter tabular-nums mb-2">
                    {currentTime.toLocaleTimeString('es-AR', { hour: '2-digit', minute: '2-digit', second: '2-digit' })}
                </h1>
                <p className="text-xl md:text-3xl font-bold text-slate-400 capitalize tracking-tight">
                    {currentTime.toLocaleDateString('es-AR', { weekday: 'long', day: 'numeric', month: 'long' })}
                </p>
            </div>

            <div className="bg-white p-10 md:p-16 rounded-[4rem] shadow-[0_32px_64px_-16px_rgba(0,0,0,0.1)] border border-slate-100 w-full max-w-2xl mx-auto relative overflow-hidden text-center">
                
                <div className="absolute top-0 left-0 w-full h-3 bg-gradient-to-r from-indigo-500 via-brand-500 to-indigo-600"></div>

                <div className="flex flex-col items-center mb-10">
                    <div className="w-24 h-24 bg-indigo-50 rounded-3xl flex items-center justify-center mb-6 rotate-3 shadow-inner">
                        <ScanLine className="w-12 h-12 text-indigo-600" />
                    </div>
                    <h2 className="text-4xl font-black text-slate-900 mb-2 tracking-tight">Terminal de Asistencia</h2>
                    <p className="text-slate-500 font-bold text-lg">Ingresá tu DNI para fichar</p>
                </div>

                <form onSubmit={handlePunch} className="space-y-6">
                    <div className="relative group">
                        <input 
                            ref={inputRef}
                            type="text" 
                            inputMode="numeric"
                            autoFocus
                            autoComplete="off"
                            placeholder="DNI"
                            className="w-full text-center p-8 bg-slate-50 border-4 border-slate-100 rounded-[2.5rem] outline-none focus:ring-8 focus:ring-indigo-500/10 focus:border-indigo-500 focus:bg-white transition-all text-5xl font-black text-slate-900 tracking-widest placeholder:text-slate-200"
                            value={inputValue}
                            onChange={(e) => setInputValue(e.target.value)}
                            disabled={isProcessing}
                        />
                        {isProcessing && (
                            <div className="absolute inset-0 flex items-center justify-center bg-white/60 backdrop-blur-sm rounded-[2.5rem]">
                                <Loader2 className="w-12 h-12 animate-spin text-indigo-600" />
                            </div>
                        )}
                    </div>

                    <button 
                        type="submit"
                        disabled={isProcessing || !inputValue}
                        className="w-full py-6 bg-slate-900 hover:bg-black text-white rounded-[2rem] font-black text-2xl transition-all active:scale-95 disabled:opacity-50 shadow-2xl shadow-slate-900/20"
                    >
                        {isProcessing ? 'PROCESANDO...' : 'REGISTRAR'}
                    </button>
                </form>

                <div className="mt-12 pt-8 border-t border-slate-100">
                    <div className="flex justify-center gap-6 opacity-30 grayscale">
                        <div className="flex flex-col items-center gap-1">
                            <div className="w-2 h-2 rounded-full bg-slate-400"></div>
                            <span className="text-[10px] font-black uppercase tracking-tighter">Biométrico</span>
                        </div>
                        <div className="flex flex-col items-center gap-1">
                            <div className="w-2 h-2 rounded-full bg-slate-400"></div>
                            <span className="text-[10px] font-black uppercase tracking-tighter">RFID Ready</span>
                        </div>
                        <div className="flex flex-col items-center gap-1">
                            <div className="w-2 h-2 rounded-full bg-slate-400"></div>
                            <span className="text-[10px] font-black uppercase tracking-tighter">Cloud Sync</span>
                        </div>
                    </div>
                </div>
            </div>
            
            <p className="mt-10 text-slate-400 font-black text-xs uppercase tracking-[0.3em]">
                Speed Digital • {orgData.name}
            </p>
        </div>
    );
}
