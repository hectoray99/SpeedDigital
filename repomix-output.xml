                                                    <button onClick={() => removeImage(index)} className="bg-red-500 hover:bg-red-600 text-white p-2.5 rounded-full shadow-lg transition-transform hover:scale-110 active:scale-95"><Trash2 className="w-4 h-4" /></button>
