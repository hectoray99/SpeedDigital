import { useEffect, useState, Fragment } from 'react';
import { Dialog, Transition } from '@headlessui/react';
import { supabase } from '../../../lib/supabase';
import { useAuthStore } from '../../../store/authStore';
import { Plus, Search, Loader2, Edit2, X, Save, Users, Clock, DollarSign, Dumbbell, User as UserIcon } from 'lucide-react';
import { toast } from 'sonner';

// ==========================================
// INTERFACES
// ==========================================
interface Resource {
    id: string;
    name: string;
}

interface Discipline {
    id: string;
    name: string;
    price: number;
    is_active: boolean;
    // Usamos estrictamente la columna 'properties' de la BD
    properties: {
        description?: string;
        capacity: number;
        duration_minutes: number;
        resource_id: string | null;
    };
}

export default function DisciplineManager() {
    const { orgData } = useAuthStore();
    const [disciplines, setDisciplines] = useState<Discipline[]>([]);
    const [resources, setResources] = useState<Resource[]>([]);
    const [loading, setLoading] = useState(true);
    const [searchTerm, setSearchTerm] = useState('');

    // Estados del Modal
    const [isModalOpen, setIsModalOpen] = useState(false);
    const [isSaving, setIsSaving] = useState(false);
    const [editingId, setEditingId] = useState<string | null>(null);
    
    const [formData, setFormData] = useState({
        name: '',
        description: '',
        price: '',
        capacity: '15',
        duration_minutes: '60',
        resource_id: ''
    });

    // =========================================================================
    // INICIALIZACIÓN
    // =========================================================================
    useEffect(() => {
        if (orgData?.id) {
            fetchData();
        }
    }, [orgData?.id]);

    async function fetchData() {
        try {
            setLoading(true);
            
            const { data: resourcesData, error: resError } = await supabase
                .from('resources')
                .select('id, name')
                .eq('organization_id', orgData!.id)
                .eq('is_active', true);
            
            if (resError) throw resError;
            setResources(resourcesData || []);

            const { data: catalogData, error: catError } = await supabase
                .from('catalog_items')
                .select('*')
                .eq('organization_id', orgData!.id)
                .eq('type', 'service') 
                .order('name', { ascending: true });

            if (catError) throw catError;
            
            // Mapeamos asegurando que la estructura 'properties' exista
            const mappedDisciplines = (catalogData || []).map(item => ({
                ...item,
                properties: item.properties || { description: '', capacity: 1, duration_minutes: 60, resource_id: null }
            }));
            
            setDisciplines(mappedDisciplines);

        } catch (error) {
            console.error(error);
            toast.error('Error al cargar la base de datos de servicios.');
        } finally {
            setLoading(false);
        }
    }

    // =========================================================================
    // LÓGICA DE FORMULARIO Y GUARDADO
    // =========================================================================
    const openModal = (discipline?: Discipline) => {
        if (discipline) {
            setEditingId(discipline.id);
            setFormData({
                name: discipline.name,
                description: discipline.properties?.description || '', // Leemos desde properties
                price: discipline.price.toString(),
                capacity: discipline.properties?.capacity?.toString() || '15',
                duration_minutes: discipline.properties?.duration_minutes?.toString() || '60',
                resource_id: discipline.properties?.resource_id || ''
            });
        } else {
            setEditingId(null);
            setFormData({ name: '', description: '', price: '', capacity: '15', duration_minutes: '60', resource_id: '' });
        }
        setIsModalOpen(true);
    };

    const handleSave = async (e: React.FormEvent) => {
        e.preventDefault();
        if (!orgData?.id) return;
        
        setIsSaving(true);

        // Armamos el payload respetando el esquema de catalog_items
        const payload = {
            organization_id: orgData.id,
            name: formData.name.trim(),
            price: Number(formData.price),
            type: 'service', 
            is_active: true,
            // Guardamos todo lo extra en 'properties'
            properties: {
                description: formData.description.trim(),
                capacity: Number(formData.capacity),
                duration_minutes: Number(formData.duration_minutes),
                resource_id: formData.resource_id || null
            }
        };

        try {
            if (editingId) {
                const { error } = await supabase.from('catalog_items').update(payload).eq('id', editingId);
                if (error) throw error;
                toast.success('Disciplina actualizada correctamente.');
            } else {
                const { error } = await supabase.from('catalog_items').insert([payload]);
                if (error) throw error;
                toast.success('Nueva disciplina creada.');
            }
            
            setIsModalOpen(false);
            fetchData();
        } catch (error: any) {
            console.error(error);
            toast.error(error.message || 'Error al guardar la disciplina.');
        } finally {
            setIsSaving(false);
        }
    };

    const toggleStatus = async (id: string, currentStatus: boolean) => {
        try {
            const { error } = await supabase.from('catalog_items').update({ is_active: !currentStatus }).eq('id', id);
            if (error) throw error;
            fetchData();
        } catch (error) {
            toast.error('Error al cambiar el estado.');
        }
    };

    // =========================================================================
    // FILTROS Y BÚSQUEDA
    // =========================================================================
    const filteredDisciplines = disciplines.filter(d => 
        d.name.toLowerCase().includes(searchTerm.toLowerCase()) || 
        d.properties?.description?.toLowerCase().includes(searchTerm.toLowerCase())
    );

    // =========================================================================
    // RENDER PRINCIPAL
    // =========================================================================
    return (
        <div className="animate-in fade-in duration-500 max-w-7xl mx-auto pb-12">
            
            {/* CABECERA */}
            <div className="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
                <div>
                    <h1 className="text-3xl font-black text-slate-800 tracking-tight flex items-center gap-3">
                        <div className="p-2 bg-indigo-100 rounded-xl"><Dumbbell className="w-6 h-6 text-indigo-600" /></div>
                        Gestión de Disciplinas
                    </h1>
                    <p className="text-slate-500 mt-1 font-medium text-sm sm:text-base">Administrá los servicios, cupos máximos y profes a cargo.</p>
                </div>
                <button
                    onClick={() => openModal()}
                    className="w-full sm:w-auto bg-indigo-600 hover:bg-indigo-500 text-white px-6 py-3.5 rounded-xl flex items-center justify-center gap-2 font-bold shadow-lg shadow-indigo-500/30 transition-all active:scale-95"
                >
                    <Plus className="w-5 h-5" />
                    Nueva Disciplina
                </button>
            </div>

            {/* BARRA DE BÚSQUEDA */}
            <div className="bg-white p-2 rounded-2xl shadow-sm border border-slate-200 mb-6">
                <div className="relative">
                    <Search className="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 w-5 h-5" />
                    <input
                        type="text"
                        placeholder="Buscar disciplina o servicio..."
                        className="w-full pl-12 pr-4 py-3.5 rounded-xl bg-slate-50 outline-none focus:ring-2 focus:ring-indigo-500/20 focus:bg-white transition-all text-slate-800 font-bold"
                        value={searchTerm}
                        onChange={(e) => setSearchTerm(e.target.value)}
                    />
                </div>
            </div>

            {/* GRILLA DE TARJETAS */}
            {loading ? (
                <div className="p-16 flex flex-col items-center justify-center text-slate-400 gap-4 h-full bg-white rounded-3xl border border-slate-200 shadow-sm">
                    <Loader2 className="w-10 h-10 animate-spin text-indigo-500" />
                    <p className="font-bold tracking-widest uppercase text-xs">Cargando catálogo...</p>
                </div>
            ) : filteredDisciplines.length === 0 ? (
                <div className="p-16 text-center text-slate-500 flex flex-col items-center justify-center h-full bg-white rounded-3xl border border-slate-200 shadow-sm">
                    <div className="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mb-6 border border-slate-100 shadow-sm">
                        <Dumbbell className="w-10 h-10 text-slate-300" />
                    </div>
                    <h3 className="text-2xl font-black text-slate-700">No hay disciplinas</h3>
                    <p className="mt-2 max-w-sm font-medium">Aún no configuraste ningún servicio. Creá uno nuevo para empezar a agendar alumnos.</p>
                </div>
            ) : (
                <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    {filteredDisciplines.map((item) => {
                        const assignedProfe = resources.find(r => r.id === item.properties?.resource_id)?.name;
                        
                        return (
                            <div key={item.id} className={`bg-white rounded-3xl border shadow-sm p-6 flex flex-col transition-all hover:shadow-md ${item.is_active ? 'border-slate-200' : 'border-slate-200 opacity-60 grayscale-[50%]'}`}>
                                
                                <div className="flex justify-between items-start mb-4">
                                    <h3 className="text-xl font-black text-slate-800 leading-tight">{item.name}</h3>
                                    <div className="flex items-center gap-1 bg-emerald-50 text-emerald-700 px-2.5 py-1 rounded-lg border border-emerald-100 font-black text-sm shrink-0">
                                        <DollarSign className="w-3.5 h-3.5" /> {item.price.toLocaleString()}
                                    </div>
                                </div>
                                
                                <p className="text-sm text-slate-500 mb-6 flex-1 font-medium">{item.properties?.description || 'Sin descripción detallada.'}</p>
                                
                                {/* Info extendida (Properties) */}
                                <div className="space-y-2 mb-6 bg-slate-50 p-4 rounded-2xl border border-slate-100">
                                    <div className="flex items-center justify-between text-sm">
                                        <span className="flex items-center gap-2 text-slate-500 font-bold"><Users className="w-4 h-4" /> Cupo Máximo</span>
                                        <span className="font-black text-slate-800">{item.properties?.capacity || 1} alumnos</span>
                                    </div>
                                    <div className="flex items-center justify-between text-sm">
                                        <span className="flex items-center gap-2 text-slate-500 font-bold"><Clock className="w-4 h-4" /> Duración</span>
                                        <span className="font-black text-slate-800">{item.properties?.duration_minutes || 60} min</span>
                                    </div>
                                    <div className="flex items-center justify-between text-sm pt-2 border-t border-slate-200 mt-2">
                                        <span className="flex items-center gap-2 text-slate-500 font-bold"><UserIcon className="w-4 h-4" /> Profe / Encargado</span>
                                        <span className="font-black text-indigo-600 bg-indigo-50 px-2 py-0.5 rounded truncate max-w-[120px] text-right">
                                            {assignedProfe || 'Sin asignar'}
                                        </span>
                                    </div>
                                </div>

                                {/* Acciones */}
                                <div className="flex items-center justify-between pt-4 border-t border-slate-100">
                                    <button 
                                        onClick={() => toggleStatus(item.id, item.is_active)}
                                        className={`text-xs font-bold uppercase tracking-widest px-3 py-1.5 rounded-lg transition-colors ${item.is_active ? 'text-slate-500 hover:bg-slate-100' : 'text-emerald-600 bg-emerald-50 hover:bg-emerald-100'}`}
                                    >
                                        {item.is_active ? 'Desactivar' : 'Activar'}
                                    </button>
                                    
                                    <div className="flex items-center gap-2">
                                        <button onClick={() => openModal(item)} className="p-2 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-xl transition-colors">
                                            <Edit2 className="w-4 h-4" />
                                        </button>
                                    </div>
                                </div>
                            </div>
                        );
                    })}
                </div>
            )}

            {/* ========================================================================= */}
            {/* MODAL DE CREACIÓN / EDICIÓN */}
            {/* ========================================================================= */}
            <Transition appear show={isModalOpen} as={Fragment}>
                <Dialog as="div" className="relative z-[99999]" onClose={() => !isSaving && setIsModalOpen(false)}>
                    <div className="fixed inset-0 bg-slate-900/60 backdrop-blur-sm transition-opacity" />

                    <div className="fixed inset-0 overflow-y-auto">
                        <div className="flex min-h-full items-center justify-center p-4">
                            <Dialog.Panel className="w-full max-w-lg transform overflow-hidden rounded-3xl bg-white text-left align-middle shadow-2xl transition-all animate-in zoom-in-95 duration-200">
                                
                                <div className="flex justify-between items-center p-6 border-b border-slate-100 bg-slate-50 shrink-0">
                                    <Dialog.Title as="h3" className="text-xl font-black text-slate-800 flex items-center gap-2">
                                        <div className="p-2 bg-indigo-100 rounded-xl"><Dumbbell className="w-5 h-5 text-indigo-600" /></div>
                                        {editingId ? 'Editar Disciplina' : 'Nueva Disciplina'}
                                    </Dialog.Title>
                                    <button onClick={() => setIsModalOpen(false)} disabled={isSaving} className="p-2 hover:bg-slate-200 rounded-xl transition-colors disabled:opacity-50">
                                        <X className="w-5 h-5 text-slate-400" />
                                    </button>
                                </div>

                                <form onSubmit={handleSave} className="p-6 md:p-8 space-y-5 max-h-[75vh] overflow-y-auto hide-scrollbar">
                                    
                                    <div>
                                        <label className="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Nombre de la Actividad *</label>
                                        <input required type="text" className="w-full px-4 py-3.5 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-indigo-500/20 focus:bg-white font-bold text-slate-800 transition-all" value={formData.name} onChange={e => setFormData({ ...formData, name: e.target.value })} placeholder="Ej: Crossfit, Funcional, Zumba..." />
                                    </div>

                                    <div>
                                        <label className="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Descripción (Opcional)</label>
                                        <textarea className="w-full p-4 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-indigo-500/20 focus:bg-white resize-none h-24 font-medium text-slate-700 transition-all" value={formData.description} onChange={e => setFormData({ ...formData, description: e.target.value })} placeholder="Breve detalle de la clase..." />
                                    </div>

                                    <div className="grid grid-cols-2 gap-4">
                                        <div>
                                            <label className="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Precio por clase *</label>
                                            <div className="relative">
                                                <DollarSign className="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 w-4 h-4" />
                                                <input required type="number" min="0" step="0.01" className="w-full pl-9 pr-4 py-3.5 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-indigo-500/20 focus:bg-white font-black text-slate-800 transition-all" value={formData.price} onChange={e => setFormData({ ...formData, price: e.target.value })} placeholder="0" />
                                            </div>
                                        </div>
                                        <div>
                                            <label className="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Duración (Minutos) *</label>
                                            <div className="relative">
                                                <Clock className="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 w-4 h-4" />
                                                <input required type="number" min="1" className="w-full pl-9 pr-4 py-3.5 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-indigo-500/20 focus:bg-white font-black text-slate-800 transition-all" value={formData.duration_minutes} onChange={e => setFormData({ ...formData, duration_minutes: e.target.value })} placeholder="60" />
                                            </div>
                                        </div>
                                    </div>

                                    <div className="pt-4 border-t border-slate-100 grid grid-cols-2 gap-4">
                                        <div>
                                            <label className=" text-xs font-bold text-emerald-600 uppercase tracking-widest mb-2 flex items-center gap-1"><Users className="w-3 h-3" /> Cupo Máximo *</label>
                                            <input required type="number" min="1" className="w-full px-4 py-3.5 bg-emerald-50/50 border border-emerald-200 rounded-xl outline-none focus:ring-2 focus:ring-emerald-500/20 focus:bg-white font-black text-emerald-800 transition-all text-center" value={formData.capacity} onChange={e => setFormData({ ...formData, capacity: e.target.value })} placeholder="15" />
                                            <p className="text-[10px] text-slate-400 mt-1 font-medium leading-tight">Límite de alumnos por horario para evitar sobreventa.</p>
                                        </div>

                                        <div>
                                            <label className=" text-xs font-bold text-indigo-600 uppercase tracking-widest mb-2 flex items-center gap-1"><UserIcon className="w-3 h-3" /> Profesor Asignado</label>
                                            <select className="w-full px-4 py-3.5 bg-indigo-50/50 border border-indigo-200 rounded-xl outline-none focus:ring-2 focus:ring-indigo-500/20 focus:bg-white font-bold text-indigo-900 transition-all appearance-none cursor-pointer" value={formData.resource_id} onChange={e => setFormData({ ...formData, resource_id: e.target.value })}>
                                                <option value="">-- Sin asignar --</option>
                                                {resources.map(res => (
                                                    <option key={res.id} value={res.id}>{res.name}</option>
                                                ))}
                                            </select>
                                            <p className="text-[10px] text-slate-400 mt-1 font-medium leading-tight">Vincular para liquidar comisiones a fin de mes.</p>
                                        </div>
                                    </div>

                                    <div className="pt-6 border-t border-slate-100">
                                        <button type="submit" disabled={isSaving} className="w-full py-4 bg-indigo-600 hover:bg-indigo-500 text-white rounded-xl font-black flex justify-center items-center gap-2 disabled:opacity-50 transition-all shadow-xl shadow-indigo-500/20 active:scale-95 text-lg">
                                            {isSaving ? <Loader2 className="w-5 h-5 animate-spin" /> : <Save className="w-5 h-5" />} 
                                            {isSaving ? 'Guardando...' : 'Guardar Disciplina'}
                                        </button>
                                    </div>
                                </form>
                                
                            </Dialog.Panel>
                        </div>
                    </div>
                </Dialog>
            </Transition>

        </div>
    );
}
</file>

