            <div className="bg-white w-full max-w-2xl rounded-3xl shadow-xl shadow-slate-200/50 overflow-hidden border border-slate-100 animate-in zoom-in-95 duration-300">
                
                {/* --- PASO 1: ELEGIR RUBRO --- */}
