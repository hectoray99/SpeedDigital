                                                        {person.full_name.charAt(0).toUpperCase()}
                                                    </div>
                                                    <div>
                                                        <div className="font-bold text-slate-800 text-base">{person.full_name}</div>
                                                        <div className="text-xs text-slate-500 font-medium flex items-center gap-1 mt-0.5">
